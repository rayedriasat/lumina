{
  "name": "lumina",
  "version": "2.2.3",
  "description": "A self-hosted, zero-backend, glassmorphism PWA that turns your offline course folders into a beautiful, sequential learning experience.",
  "main": "server.js",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.11.2",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "node server.js",
    "css": "tailwindcss -c tailwind.config.js -i tailwind.input.css -o css/tailwind.css --minify",
    "css:watch": "tailwindcss -c tailwind.config.js -i tailwind.input.css -o css/tailwind.css --watch",
    "prebuild": "npm run css",
    "build": "node build-web.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rayedriasat/lumina.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rayedriasat/lumina/issues"
  },
  "homepage": "https://github.com/rayedriasat/lumina#readme",
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1"
  }
}
