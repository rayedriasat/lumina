{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lumina",
  "version": "2.2.3",
  "identifier": "com.lumina.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3321/",
    "beforeDevCommand": "",
    "beforeBuildCommand": "node build-web.js"
  },
  "app": {
    "windows": [
      {
        "title": "Lumina",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
